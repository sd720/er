@model ItemProcessorApp.Models.Item
@{
    ViewData["Title"] = "Edit Item";
}

<div class="page-header">
    <div>
        <h2>✏️ Edit Item</h2>
        <p class="page-desc">Update item details below.</p>
    </div>
    <a href="/Items/Index" class="btn btn-ghost">← Back to Items</a>
</div>

<div class="card form-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />

        <div class="form-group">
            <label asp-for="Name"></label>
            <input asp-for="Name" />
            <span asp-validation-for="Name" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Weight"></label>
            <input asp-for="Weight" type="number" step="0.0001" min="0.0001" />
            <span asp-validation-for="Weight" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="Description"></label>
            <textarea asp-for="Description" rows="3"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Update Item</button>
            <a href="/Items/Index" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>
