@model ItemProcessorApp.Models.Item
@{
    ViewData["Title"] = "Delete Item";
}

<div class="page-header">
    <div>
        <h2>🗑️ Delete Item</h2>
        <p class="page-desc">This action cannot be undone.</p>
    </div>
    <a href="/Items/Index" class="btn btn-ghost">← Back to Items</a>
</div>

<div class="card form-card danger-card">
    <div class="danger-icon">⚠️</div>
    <h3>Are you sure you want to delete this item?</h3>

    <div class="info-row"><span class="info-label">Name</span><strong>@Model.Name</strong></div>
    <div class="info-row"><span class="info-label">Weight</span><strong>@Model.Weight kg</strong></div>
    <div class="info-row"><span class="info-label">Description</span><span>@(Model.Description ?? "—")</span></div>
    <div class="info-row"><span class="info-label">Created</span><span>@Model.CreatedAt.ToString("MMM dd, yyyy")</span></div>

    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="form-actions">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-danger">Yes, Delete</button>
        <a href="/Items/Index" class="btn btn-ghost">Cancel</a>
    </form>
</div>
