@model ItemProcessorApp.ViewModels.ProcessItemViewModel
@{
    ViewData["Title"] = "Process Item";
}

<div class="page-header">
    <div>
        <h2>⚗️ Process Item</h2>
        <p class="page-desc">Select a parent item and define its output (child) items.</p>
    </div>
    <a href="/Process/Tree" class="btn btn-ghost">🌳 View Tree</a>
</div>

<div class="card form-card">
    <form asp-action="Create" method="post" id="processForm" novalidate>
        @Html.AntiForgeryToken()

        <h3 class="section-title">Parent Item</h3>
        <div class="form-row">
            <div class="form-group">
                <label asp-for="ParentItemId">Select Parent Item</label>
                <select asp-for="ParentItemId" asp-items="ViewBag.Items" class="form-select">
                    <option value="">-- Select an item --</option>
                </select>
                <span asp-validation-for="ParentItemId" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="ParentOutputWeight"></label>
                <input asp-for="ParentOutputWeight" type="number" step="0.0001" min="0.0001" placeholder="e.g. 450.00" />
                <span asp-validation-for="ParentOutputWeight" class="field-error"></span>
            </div>
        </div>
        <div class="form-group">
            <label asp-for="ParentNotes">Notes (optional)</label>
            <input asp-for="ParentNotes" placeholder="Notes about this processing step…" />
        </div>

        <hr class="divider" />

        <h3 class="section-title">Child Output Items</h3>
        <p class="hint">Add one or more output items generated from the processing.</p>

        <div id="children-container">
            <div class="child-item" data-index="0">
                <div class="child-header">
                    <span class="child-label">Output #1</span>
                    <button type="button" class="btn btn-sm btn-danger remove-child" style="display:none">Remove</button>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Output Item</label>
                        <select name="Children[0].ItemId" class="form-select" required>
                            <option value="">-- Select item --</option>
                            @foreach (var opt in ((Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Items))
                            {
                                <option value="@opt.Value">@opt.Text</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Output Weight (kg)</label>
                        <input type="number" name="Children[0].OutputWeight" step="0.0001" min="0.0001" placeholder="e.g. 120.00" required />
                    </div>
                </div>
                <div class="form-group">
                    <label>Notes (optional)</label>
                    <input type="text" name="Children[0].Notes" placeholder="Notes…" />
                </div>
            </div>
        </div>

        <button type="button" id="addChildBtn" class="btn btn-secondary btn-sm">+ Add Another Output</button>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Process Item</button>
            <a href="/Items" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
<script>
// Store items list from server for dynamic child rows
const itemOptions = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    ((Microsoft.AspNetCore.Mvc.Rendering.SelectList)ViewBag.Items)
        .Select(o => new { value = o.Value, text = o.Text })
));

let childCount = 1;

document.getElementById('addChildBtn').addEventListener('click', () => {
    const idx = childCount++;
    const container = document.getElementById('children-container');

    const opts = itemOptions.map(o => `<option value="${o.value}">${o.text}</option>`).join('');

    const div = document.createElement('div');
    div.className = 'child-item';
    div.dataset.index = idx;
    div.innerHTML = `
        <div class="child-header">
            <span class="child-label">Output #${idx + 1}</span>
            <button type="button" class="btn btn-sm btn-danger remove-child">Remove</button>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Output Item</label>
                <select name="Children[${idx}].ItemId" class="form-select" required>
                    <option value="">-- Select item --</option>
                    ${opts}
                </select>
            </div>
            <div class="form-group">
                <label>Output Weight (kg)</label>
                <input type="number" name="Children[${idx}].OutputWeight" step="0.0001" min="0.0001" placeholder="e.g. 120.00" required />
            </div>
        </div>
        <div class="form-group">
            <label>Notes (optional)</label>
            <input type="text" name="Children[${idx}].Notes" placeholder="Notes…" />
        </div>`;

    container.appendChild(div);
    updateRemoveButtons();
});

document.addEventListener('click', e => {
    if (e.target.classList.contains('remove-child')) {
        e.target.closest('.child-item').remove();
        updateRemoveButtons();
        renumberChildren();
    }
});

function updateRemoveButtons() {
    const items = document.querySelectorAll('.child-item');
    items.forEach((item, i) => {
        const btn = item.querySelector('.remove-child');
        btn.style.display = items.length > 1 ? 'inline-flex' : 'none';
    });
}

function renumberChildren() {
    document.querySelectorAll('.child-item .child-label').forEach((label, i) => {
        label.textContent = `Output #${i + 1}`;
    });
}
</script>
}
